# Pultrum frontend — environment template
# Copy to .env and adjust. The real .env is gitignored.

# Base URL of the Pultrum backend API.
# The frontend exposes a server-side proxy at /api that forwards here, so this
# is read at runtime (server-side) — it is NOT inlined into the client bundle.
# Production example: https://api.seudominio.com
NEXT_PUBLIC_API_URL=http://localhost:3000
